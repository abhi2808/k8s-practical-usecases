{
  "Statement": [
    {
      "Action": ["ssm:GetParameter","ec2:DescribeImages","ec2:RunInstances",
        "ec2:DescribeSubnets","ec2:DescribeSecurityGroups","ec2:DescribeLaunchTemplates",
        "ec2:DescribeInstances","ec2:DescribeInstanceTypes","ec2:DescribeInstanceTypeOfferings",
        "ec2:DescribeAvailabilityZones","ec2:DeleteLaunchTemplate","ec2:CreateTags",
        "ec2:CreateLaunchTemplate","ec2:CreateFleet","ec2:DescribeSpotPriceHistory",
        "pricing:GetProducts"],
      "Effect": "Allow", "Resource": "*", "Sid": "Karpenter"
    },
    {
      "Action": "ec2:TerminateInstances",
      "Condition": {"StringLike": {"ec2:ResourceTag/karpenter.sh/nodepool": "*"}},
      "Effect": "Allow", "Resource": "*", "Sid": "ConditionalEC2Termination"
    },
    {
      "Effect": "Allow", "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::185863138492:role/KarpenterNodeRole-karpenter",
      "Sid": "PassNodeIAMRole"
    },
    {
      "Effect": "Allow", "Action": "eks:DescribeCluster",
      "Resource": "arn:aws:eks:ap-south-1:185863138492:cluster/karpenter",
      "Sid": "EKSClusterEndpointLookup"
    },
    {
      "Sid": "AllowInstanceProfileReadActions", "Effect": "Allow",
      "Resource": "*", "Action": "iam:GetInstanceProfile"
    },
    {
      "Effect": "Allow", "Action": "iam:CreateServiceLinkedRole",
      "Resource": "arn:aws:iam::*:role/aws-service-role/spot.amazonaws.com/AWSServiceRoleForEC2Spot",
      "Sid": "CreateServiceLinkedRoleForEC2Spot"
    }
  ],
  "Version": "2012-10-17"
}
